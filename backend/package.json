{
  "name": "studydocs-market-be",
  "version": "0.1.0",
  "private": true,
  "description": "Backend API for StudyDocs Market (NestJS + Prisma + PostgreSQL)",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "seed": "ts-node prisma/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "test": "jest --config jest.config.js --runInBand",
    "test:e2e": "jest --config jest.config.js --runInBand --verbose",
    "test:e2e:part1": "jest --config jest.config.js --runInBand --verbose --testPathPatterns=01-auth",
    "test:e2e:part2": "jest --config jest.config.js --runInBand --verbose --testPathPatterns=02-documents",
    "test:e2e:part3": "jest --config jest.config.js --runInBand --verbose --testPathPatterns=03-financial",
    "test:e2e:part4": "jest --config jest.config.js --runInBand --verbose --testPathPatterns=04-interaction"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.5.0",
    "@supabase/supabase-js": "^2.101.1",
    "@types/minio": "^7.1.0",
    "@types/multer": "^2.1.0",
    "@types/passport-facebook": "^3.0.4",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "firebase-admin": "^13.7.0",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "minio": "^8.0.7",
    "multer": "^2.1.1",
    "otplib": "^13.4.0",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.13.10",
    "@types/otplib": "^7.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "jest": "^30.3.0",
    "prettier": "^3.5.3",
    "prisma": "^6.5.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.2"
  }
}
